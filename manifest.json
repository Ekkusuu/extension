{
  "manifest_version": 2,
  "name": "Clipboard Manager",
  "version": "1.0",
  "description": "Simple clipboard history and text snippets manager",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "<all_urls>",
    "*://generativelanguage.googleapis.com/*",
    "*://api.openai.com/*",
    "*://api.anthropic.com/*",
    "*://openrouter.ai/*",
    "*://api.x.ai/*"
  ],
  "web_accessible_resources": [
    "katex/katex.min.js",
    "katex/katex.min.css",
    "katex/fonts/*.woff2"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "clipboard-manager@tools.browser"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["katex/katex.min.js", "content.js"],
      "css": ["styles.css", "katex/katex.min.css"],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Clipboard Manager"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  }
}
